{
    "name": "CENV",
    "scopeName": "source.cenv",
    "fileTypes": [
        "cenv"
    ],
    "patterns": [
        {
            "comment": "Version field",
            "match": "(\"v\")\\s*:\\s*(\"[^\"]*\")",
            "captures": {
                "1": {
                    "name": "keyword.other.cenv"
                },
                "2": {
                    "name": "string.quoted.double.cenv"
                }
            }
        },
        {
            "comment": "Salt field key",
            "match": "(\"s\")\\s*:\\s*(\"[^\"]*\")",
            "captures": {
                "1": {
                    "name": "support.type.property-name.cenv"
                },
                "2": {
                    "name": "comment.line.cenv"
                }
            }
        },
        {
            "comment": "Encrypted data field key",
            "match": "(\"d\")\\s*:\\s*(\"[^\"]*\")",
            "captures": {
                "1": {
                    "name": "entity.name.tag.cenv"
                },
                "2": {
                    "name": "string.other.cenv"
                }
            }
        },
        {
            "comment": "JSON string values",
            "name": "string.quoted.double.cenv",
            "match": "\"[^\"]*\""
        },
        {
            "comment": "JSON structural characters",
            "name": "punctuation.definition.cenv",
            "match": "[{}\\[\\],:.]"
        }
    ]
}